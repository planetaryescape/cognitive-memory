{
  "name": "cognitive-memory",
  "version": "0.2.0",
  "description": "Biologically-inspired agent memory with decay, consolidation, and tiered storage",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./adapters/postgres": {
      "types": "./dist/adapters/postgres.d.ts",
      "import": "./dist/adapters/postgres.js"
    },
    "./adapters/jsonl": {
      "types": "./dist/adapters/jsonl.d.ts",
      "import": "./dist/adapters/jsonl.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts src/adapters/postgres.ts src/adapters/jsonl.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "ai",
    "memory",
    "cognitive",
    "ebbinghaus",
    "spaced-repetition",
    "forgetting-curve",
    "associative-memory",
    "llm",
    "chatbot",
    "agents"
  ],
  "author": "Bhekani Khumalo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bhekanik/cognitive-memory.git",
    "directory": "sdks/typescript"
  },
  "homepage": "https://bhekanik.github.io/cognitive-memory",
  "peerDependencies": {
    "convex": ">=1.0.0",
    "pg": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "convex": {
      "optional": true
    },
    "pg": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.19.0",
    "@types/pg": "^8.15.5",
    "convex": "^1.0.0",
    "pg": "^8.16.3",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
