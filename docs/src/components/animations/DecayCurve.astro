---
/**
 * Animated Ebbinghaus decay curve visualization.
 * Shows episodic, semantic, and core memory decay with floors.
 */

// Generate SVG path data for decay curves
function decayCurve(baseRate: number, floor: number, importance: number = 0.5): string {
	const points: string[] = [];
	const width = 600;
	const height = 200;
	const margin = { left: 50, top: 10, right: 20, bottom: 30 };
	const plotW = width - margin.left - margin.right;
	const plotH = height - margin.top - margin.bottom;
	const maxDays = 180;

	for (let day = 0; day <= maxDays; day += 2) {
		const stability = 1.0;
		const boost = 1 + importance;
		const dt = day / (stability * baseRate * boost);
		const retention = Math.max(floor, Math.exp(-dt));
		const x = margin.left + (day / maxDays) * plotW;
		const y = margin.top + (1 - retention) * plotH;
		points.push(`${day === 0 ? 'M' : 'L'}${x.toFixed(1)},${y.toFixed(1)}`);
	}
	return points.join(' ');
}

const episodicPath = decayCurve(45, 0.02);
const semanticPath = decayCurve(120, 0.02);
const corePath = decayCurve(120, 0.60);

const chartWidth = 600;
const chartHeight = 200;
const margin = { left: 50, top: 10, right: 20, bottom: 30 };
const plotH = chartHeight - margin.top - margin.bottom;

// Floor line Y positions
const coreFloorY = margin.top + (1 - 0.60) * plotH;
const regularFloorY = margin.top + (1 - 0.02) * plotH;
---

<div class="animation-container">
	<svg viewBox={`0 0 ${chartWidth} ${chartHeight + 30}`} xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Ebbinghaus decay curves showing episodic, semantic, and core memory retention over time">
		<!-- Y-axis -->
		<line x1={margin.left} y1={margin.top} x2={margin.left} y2={margin.top + plotH} stroke="var(--sl-color-gray-4)" stroke-width="1" />
		<!-- X-axis -->
		<line x1={margin.left} y1={margin.top + plotH} x2={chartWidth - margin.right} y2={margin.top + plotH} stroke="var(--sl-color-gray-4)" stroke-width="1" />

		<!-- Y-axis labels -->
		<text x={margin.left - 8} y={margin.top + 4} text-anchor="end" fill="var(--sl-color-gray-3)" font-size="10">1.0</text>
		<text x={margin.left - 8} y={coreFloorY + 4} text-anchor="end" fill="var(--sl-color-gray-3)" font-size="10">0.6</text>
		<text x={margin.left - 8} y={margin.top + plotH + 4} text-anchor="end" fill="var(--sl-color-gray-3)" font-size="10">0</text>
		<text x="14" y={margin.top + plotH / 2} text-anchor="middle" fill="var(--sl-color-gray-3)" font-size="10" transform={`rotate(-90, 14, ${margin.top + plotH / 2})`}>Retention</text>

		<!-- X-axis labels -->
		<text x={margin.left} y={chartHeight + 8} text-anchor="middle" fill="var(--sl-color-gray-3)" font-size="10">0</text>
		<text x={margin.left + (90 / 180) * (chartWidth - margin.left - margin.right)} y={chartHeight + 8} text-anchor="middle" fill="var(--sl-color-gray-3)" font-size="10">90</text>
		<text x={chartWidth - margin.right} y={chartHeight + 8} text-anchor="middle" fill="var(--sl-color-gray-3)" font-size="10">180</text>
		<text x={margin.left + (chartWidth - margin.left - margin.right) / 2} y={chartHeight + 25} text-anchor="middle" fill="var(--sl-color-gray-3)" font-size="10">Days</text>

		<!-- Floor lines -->
		<line x1={margin.left} y1={coreFloorY} x2={chartWidth - margin.right} y2={coreFloorY} stroke="var(--cm-purple)" stroke-width="1" stroke-dasharray="4 4" opacity="0.4" />
		<text x={chartWidth - margin.right + 5} y={coreFloorY + 4} fill="var(--cm-purple)" font-size="9" opacity="0.6">core floor</text>
		<line x1={margin.left} y1={regularFloorY} x2={chartWidth - margin.right} y2={regularFloorY} stroke="var(--sl-color-gray-4)" stroke-width="1" stroke-dasharray="4 4" opacity="0.3" />

		<!-- Decay curves -->
		<path d={episodicPath} fill="none" stroke="var(--cm-cyan)" stroke-width="2.5" class="curve curve-episodic" />
		<path d={semanticPath} fill="none" stroke="var(--cm-green)" stroke-width="2.5" class="curve curve-semantic" />
		<path d={corePath} fill="none" stroke="var(--cm-purple)" stroke-width="2.5" class="curve curve-core" />

		<!-- Legend -->
		<g transform={`translate(${margin.left + 20}, ${margin.top + 15})`}>
			<line x1="0" y1="0" x2="20" y2="0" stroke="var(--cm-cyan)" stroke-width="2.5" />
			<text x="26" y="4" fill="var(--sl-color-gray-2)" font-size="11">Episodic (45d)</text>

			<line x1="140" y1="0" x2="160" y2="0" stroke="var(--cm-green)" stroke-width="2.5" />
			<text x="166" y="4" fill="var(--sl-color-gray-2)" font-size="11">Semantic (120d)</text>

			<line x1="300" y1="0" x2="320" y2="0" stroke="var(--cm-purple)" stroke-width="2.5" />
			<text x="326" y="4" fill="var(--sl-color-gray-2)" font-size="11">Core (0.60 floor)</text>
		</g>
	</svg>
</div>

<style>
	.curve {
		stroke-dasharray: 800;
		stroke-dashoffset: 800;
		animation: draw-curve 2.5s ease-out forwards;
	}
	.curve-episodic { animation-delay: 0.2s; }
	.curve-semantic { animation-delay: 0.6s; }
	.curve-core { animation-delay: 1s; }

	@keyframes draw-curve {
		to { stroke-dashoffset: 0; }
	}
</style>
