---
/**
 * Three-stage retrieval pipeline diagram.
 * Shows: Embedding Recall → R^α Scoring → LLM Re-ranking
 */
---

<div class="animation-container">
	<svg viewBox="0 0 750 160" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Three-stage retrieval pipeline: Embedding Recall, R-alpha Scoring, LLM Re-ranking">
		<defs>
			<linearGradient id="pipe-grad-1" x1="0%" y1="0%" x2="100%" y2="0%">
				<stop offset="0%" stop-color="var(--cm-cyan)" stop-opacity="0.15" />
				<stop offset="100%" stop-color="var(--cm-cyan)" stop-opacity="0.05" />
			</linearGradient>
			<linearGradient id="pipe-grad-2" x1="0%" y1="0%" x2="100%" y2="0%">
				<stop offset="0%" stop-color="var(--cm-purple)" stop-opacity="0.15" />
				<stop offset="100%" stop-color="var(--cm-purple)" stop-opacity="0.05" />
			</linearGradient>
			<linearGradient id="pipe-grad-3" x1="0%" y1="0%" x2="100%" y2="0%">
				<stop offset="0%" stop-color="var(--cm-green)" stop-opacity="0.15" />
				<stop offset="100%" stop-color="var(--cm-green)" stop-opacity="0.05" />
			</linearGradient>
		</defs>

		<!-- Stage 1: Embedding Recall -->
		<g class="pipe-stage ps1">
			<rect x="10" y="20" width="210" height="80" rx="12" fill="url(#pipe-grad-1)" stroke="var(--cm-cyan)" stroke-width="1.5" class="stage-box" />
			<text x="115" y="52" text-anchor="middle" fill="var(--cm-cyan)" font-size="14" font-weight="600">Embedding Recall</text>
			<text x="115" y="72" text-anchor="middle" fill="var(--sl-color-gray-3)" font-size="11">top_k x 3 candidates</text>
			<text x="115" y="130" text-anchor="middle" fill="var(--sl-color-gray-4)" font-size="10">Stage 1</text>
		</g>

		<!-- Arrow 1→2 -->
		<g class="pipe-arrow pa1">
			<line x1="230" y1="60" x2="270" y2="60" stroke="var(--sl-color-gray-3)" stroke-width="2" stroke-dasharray="6 3" class="pipe-arrow-line" />
			<polygon points="270,55 280,60 270,65" fill="var(--sl-color-gray-3)" />
		</g>

		<!-- Stage 2: R^α Scoring -->
		<g class="pipe-stage ps2">
			<rect x="280" y="20" width="210" height="80" rx="12" fill="url(#pipe-grad-2)" stroke="var(--cm-purple)" stroke-width="1.5" class="stage-box" />
			<text x="385" y="52" text-anchor="middle" fill="var(--cm-purple)" font-size="14" font-weight="600">R&#x3B1; Temporal Scoring</text>
			<text x="385" y="72" text-anchor="middle" fill="var(--sl-color-gray-3)" font-size="11">score = sim x R^0.3</text>
			<text x="385" y="130" text-anchor="middle" fill="var(--sl-color-gray-4)" font-size="10">Stage 2</text>
		</g>

		<!-- Arrow 2→3 -->
		<g class="pipe-arrow pa2">
			<line x1="500" y1="60" x2="540" y2="60" stroke="var(--sl-color-gray-3)" stroke-width="2" stroke-dasharray="6 3" class="pipe-arrow-line" />
			<polygon points="540,55 550,60 540,65" fill="var(--sl-color-gray-3)" />
		</g>

		<!-- Stage 3: LLM Re-ranking -->
		<g class="pipe-stage ps3">
			<rect x="550" y="20" width="190" height="80" rx="12" fill="url(#pipe-grad-3)" stroke="var(--cm-green)" stroke-width="1.5" class="stage-box" />
			<text x="645" y="52" text-anchor="middle" fill="var(--cm-green)" font-size="14" font-weight="600">LLM Re-ranking</text>
			<text x="645" y="72" text-anchor="middle" fill="var(--sl-color-gray-3)" font-size="11">gpt-4o-mini scores 1-10</text>
			<text x="645" y="130" text-anchor="middle" fill="var(--sl-color-gray-4)" font-size="10">Stage 3</text>
		</g>
	</svg>
</div>

<style>
	.stage-box {
		animation: box-glow 4s ease-in-out infinite;
	}
	.ps1 .stage-box { animation-delay: 0s; }
	.ps2 .stage-box { animation-delay: 1.3s; }
	.ps3 .stage-box { animation-delay: 2.6s; }

	@keyframes box-glow {
		0%, 100% { stroke-width: 1.5; opacity: 1; }
		25% { stroke-width: 2.5; opacity: 1; }
		50% { stroke-width: 1.5; opacity: 1; }
	}

	.pipe-arrow-line {
		animation: pipe-flow 1.2s linear infinite;
	}
	.pa1 .pipe-arrow-line { animation-delay: 0.6s; }
	.pa2 .pipe-arrow-line { animation-delay: 1.9s; }

	@keyframes pipe-flow {
		to { stroke-dashoffset: -18; }
	}
</style>
